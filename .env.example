# ─── Database ─────────────────────────────────────────────────────────────────
# Used by the API. asyncpg driver required for async SQLAlchemy.
DATABASE_URL=postgresql+asyncpg://voiceai:password@postgres:5432/voiceai
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=voiceai
DATABASE_USER=voiceai
DATABASE_PASSWORD=changeme_in_production

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python scripts/generate-keys.py
# SECRET_KEY must be ≥32 chars; used for JWT signing and CSRF tokens
SECRET_KEY=your-secret-key-min-32-chars-change-this
# ENCRYPTION_KEY is a Fernet key (44-char base64); used for encrypting stored API keys
ENCRYPTION_KEY=your-fernet-key-44-chars-base64-change-this

# ─── AI Provider Keys ─────────────────────────────────────────────────────────
# Platform-level defaults. Users can override these per-workspace via BYOK.
# Leave blank to require all users to supply their own keys.
OPENAI_DEFAULT_API_KEY=
GOOGLE_DEFAULT_API_KEY=

# Used by the platform for post-call summarization and memory extraction
ANTHROPIC_API_KEY=

# ─── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=info
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
# Maximum audio chunk size accepted by the WebSocket endpoint (bytes)
MAX_AUDIO_CHUNK_BYTES=65536

# ─── Frontend ─────────────────────────────────────────────────────────────────
# These are baked into the Next.js build at build time
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ─── Celery ───────────────────────────────────────────────────────────────────
# Use separate Redis databases to keep task queues isolated from app cache
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Storage (optional) ───────────────────────────────────────────────────────
# Leave blank to use local filesystem storage instead of S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# ─── Email (optional) ─────────────────────────────────────────────────────────
# SMTP settings for transactional email (account activation, notifications)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@voiceai.local

# ─── Monitoring (optional) ────────────────────────────────────────────────────
# Sentry DSN for error tracking — leave blank to disable
SENTRY_DSN=
# Prometheus metrics endpoint — set to false to disable
ENABLE_METRICS=true

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Toggle platform-level features without code changes
ENABLE_BYOK=true
ENABLE_MCP_INTEGRATIONS=true
ENABLE_MEMORY=true
ENABLE_ANALYTICS=true
