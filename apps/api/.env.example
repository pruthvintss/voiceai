# ============================================================
# Voice AI Platform - Environment Variables
# ============================================================

# --- Database ---
# PostgreSQL connection string with asyncpg driver
DATABASE_URL=postgresql+asyncpg://voiceai:password@localhost:5432/voiceai_db
# Sync URL for Alembic migrations
DATABASE_SYNC_URL=postgresql://voiceai:password@localhost:5432/voiceai_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Security ---
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-jwt-key-change-in-production
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-base64-encoded

# JWT settings
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- AI Provider Keys (platform fallback keys) ---
# Used when users don't provide their own keys (BYOK)
OPENAI_DEFAULT_API_KEY=sk-...
AZURE_OPENAI_DEFAULT_API_KEY=
AZURE_OPENAI_DEFAULT_ENDPOINT=https://your-resource.openai.azure.com
GOOGLE_DEFAULT_API_KEY=AIza...

# --- Anthropic (for memory extraction & summarization) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Embedding Model ---
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# --- Memory & Context Settings ---
MAX_CONTEXT_TOKENS=8000
MEMORY_SIMILARITY_THRESHOLD=0.75
MEMORY_TOP_K=20
RECENT_CONVERSATIONS_LIMIT=5

# --- Application Settings ---
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
APP_NAME=Voice AI Platform
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# --- Sentry (optional) ---
SENTRY_DSN=

# --- Audio Settings ---
AUDIO_SAMPLE_RATE=24000
AUDIO_CHANNELS=1
AUDIO_FORMAT=pcm16

# --- File Storage (optional S3 for audio recordings) ---
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
